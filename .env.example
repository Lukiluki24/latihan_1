# Google OAuth (console.cloud.google.com -> Credentials -> OAuth client ID)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# JWT — dipakai BERSAMA oleh auth-service (issue token) & user-service (validasi
# token buat endpoint avatar), harus persis sama di kedua service.
JWT_SECRET=change_this_to_a_random_secret

# SMTP (contoh pakai Mailtrap sandbox, ganti sesuai punya kamu)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USERNAME=your_mailtrap_username
SMTP_PASSWORD=your_mailtrap_password
SMTP_FROM=noreply@example.com

# Postgres (1 container, tapi bikin 2 database: auth_db & user_db)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# SeaweedFS (blob storage buat avatar, dipakai user-service) — cukup 1 container
# `weed server -s3`, jalan tanpa auth (Allow-All Mode) jadi gak butuh access/secret
# key asli. SEAWEEDFS_S3_ENDPOINT & SEAWEEDFS_BUCKET sudah di-hardcode di
# docker-compose.yml, gak perlu ditambahin ke .env kecuali mau override.
